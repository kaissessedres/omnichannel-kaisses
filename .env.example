# ================================================================
# MEGACHAT BRIDGE — Variáveis de ambiente
# ================================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env — ele está no .gitignore.
#
# ATENÇÃO — URLs internas Docker:
#   Em produção (Oracle Cloud), LIBREDESK_URL e EVOLUTION_API_URL
#   são sobrescritos pelo docker-compose.yml com os endereços internos
#   da rede Docker (http://libredesk:9000 e http://evolution:8080).
#   Só edite essas URLs se estiver rodando o bridge FORA do Docker Compose.
# ================================================================

# ── Banco de dados do Libredesk (usado pelo docker-compose.yml) ──
# Senha do PostgreSQL — defina antes do primeiro `docker compose up`
POSTGRES_PASSWORD=

# ── Libredesk ────────────────────────────────────────────────────
# Em produção: sobrescrito pelo docker-compose para http://libredesk:9000
# Em dev local (fora do Docker): use http://localhost:9000
LIBREDESK_URL=http://libredesk:9000
# API key: Libredesk > Configurações > API > Gerar nova chave
LIBREDESK_API_KEY=
# ID da conta no Libredesk (normalmente é 1)
LIBREDESK_ACCOUNT_ID=1

# ── Evolution API (WhatsApp) ─────────────────────────────────────
# Em produção: sobrescrito pelo docker-compose para http://evolution:8080
# Em dev local (fora do Docker): use http://localhost:8080
EVOLUTION_API_URL=http://evolution:8080
# API key definida em AUTHENTICATION_API_KEY no docker-compose.yml
EVOLUTION_API_KEY=
# Nome da instância criada no Evolution API (você define)
EVOLUTION_WA_INSTANCE=megachat-wa-1

# ── Segurança ────────────────────────────────────────────────────
# Chave para criptografar tokens OAuth no banco (ML, Instagram, Shopee)
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Mercado Livre ────────────────────────────────────────────────
# Obter em: https://developers.mercadolivre.com.br
ML_APP_ID=
ML_APP_SECRET=
# Refresh tokens gerados no fluxo OAuth por conta
ML_ACCOUNT_1_REFRESH_TOKEN=
ML_ACCOUNT_2_REFRESH_TOKEN=

# ── Instagram ────────────────────────────────────────────────────
# Obter em: https://developers.facebook.com
META_APP_ID=
META_APP_SECRET=
# Token de longa duração (60 dias) — gerado no fluxo OAuth
INSTAGRAM_ACCESS_TOKEN=

# ── Shopee (P2 — preencher apenas na Fase 10) ───────────────────
# Obter em: https://open.shopee.com
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_ACCOUNT_1_TOKEN=
SHOPEE_ACCOUNT_2_TOKEN=

# ── Servidor ─────────────────────────────────────────────────────
WEBHOOK_PORT=3000
# Opcional, mas recomendado assim que o bridge estiver exposto na internet.
# Valide a MESMA string nos dois lados — aqui e em Libredesk > Admin >
# Integrations > Webhooks — pra que o Libredesk assine cada chamada
# (HMAC-SHA256, header X-Libredesk-Signature) e o bridge confira a assinatura
# antes de rotear a resposta. Em branco = nenhuma validação (apenas um aviso
# no log); valor errado/só de um lado = todo webhook é rejeitado com 401.
WEBHOOK_SECRET=

# ── Túnel Cloudflare (só no deploy desktop — Nível B) ────────────
# Token do túnel nomeado (Cloudflare Zero Trust > Networks > Tunnels).
# Usado APENAS quando se sobe o docker-compose.tunnel.yml para expor o
# Libredesk com HTTPS pública. Ver docs/DEPLOY-desktop.md §4.2.
# Deixe em branco no deploy Oracle e no Nível A (local).
CLOUDFLARE_TUNNEL_TOKEN=

# ── Banco de dados do Bridge (SQLite) ────────────────────────────
# Caminho do arquivo SQLite — deixe em branco para usar ./data/megachat.db
DB_PATH=
