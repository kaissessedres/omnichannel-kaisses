{
  "name": "megachat-bridge",
  "version": "1.0.0",
  "description": "Bridge service that centralizes WhatsApp, Instagram, Mercado Livre and Shopee messages into Libredesk",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "add-account": "node scripts/add-account.js",
    "accounts": "node scripts/add-account.js --list",
    "test": "node --test test/*.test.js test/*/*.test.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "mercadolibre": "^0.0.13",
    "node-cron": "^3.0.3"
  }
}
